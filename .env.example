# Copy to .env.local for dev. In prod (Netlify), set these in the
# site's Environment variables panel.

# Replace this with at least 32 random chars in production.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Optional: override the canonical site URL used in sitemap, OG tags,
# JSON-LD links. Defaults to https://udvash-unmesh-e-commerce.netlify.app
NEXT_PUBLIC_SITE_URL=

# Postgres connection — pooled endpoint (pgbouncer) for runtime queries.
# Required. Get one free at https://neon.tech. The connection string
# must include `?pgbouncer=true` so Prisma disables prepared statements
# (pgbouncer in transaction mode doesn't support them).
#
# Example shape (Neon):
#   postgresql://user:pass@ep-XXX-pooler.REGION.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connect_timeout=10
DATABASE_URL=

# Postgres connection — direct (non-pooled) endpoint for `prisma migrate`.
# Required. Same Neon project, hostname without `-pooler`.
#
# Example shape:
#   postgresql://user:pass@ep-XXX.REGION.aws.neon.tech/dbname?sslmode=require
DIRECT_URL=

# Comma-separated emails that get admin access to /admin.
# Default in dev: admin@udvash.com,super@udvash.com
ADMIN_EMAILS=

# Resend (email provider). Optional — if unset, emails fall back to
# console.info() in the function logs (visible to whoever can read
# Vercel function logs). Sign up at https://resend.com (free tier
# 3000 emails/mo).
#
# RESEND_API_KEY      `re_xxxxxxxxxxxxxxxxxxxx`
# RESEND_FROM_EMAIL   verified sender, or `onboarding@resend.dev`
#                     (Resend's default for testing — works without
#                     domain verification)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
